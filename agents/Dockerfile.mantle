FROM node:20-alpine
WORKDIR /app
# Native module build deps (better-sqlite3 has no musl prebuilt binaries)
RUN apk add --no-cache python3 make g++ libc6-compat
COPY package*.json ./
RUN npm ci
COPY tsconfig.json ./
COPY src ./src
ENV MANTLE_SKILL_PORT=3005
EXPOSE 3005
CMD ["node_modules/.bin/tsx", "src/mantle-skills.ts", "--serve"]
