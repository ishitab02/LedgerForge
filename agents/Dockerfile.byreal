FROM node:20-alpine
WORKDIR /app
# Native module build deps (better-sqlite3 has no musl prebuilt binaries)
RUN apk add --no-cache python3 make g++ libc6-compat
COPY package*.json ./
RUN npm ci
COPY tsconfig.json ./
COPY src ./src
ENV BYREAL_SKILL_PORT=3006
EXPOSE 3006
CMD ["node_modules/.bin/tsx", "src/byreal-skills.ts", "--serve"]
