# ── Mantle Network ────────────────────────────────────────────────────────────
MANTLE_RPC=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5000
MANTLE_EXPLORER=https://mantlescan.xyz

# ── Keys (NEVER commit real values) ───────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x          # wallet used for `forge script --broadcast`
OPERATOR_PRIVATE_KEY=0x          # facilitator hot wallet; must be on ERC-8004 allowlist

# ── Deployed Contracts (fill after `forge script Deploy.s.sol --broadcast`) ───
SKILL_REGISTRY_ADDRESS=
X402_ESCROW_ADDRESS=
BAZAAR_LISTINGS_ADDRESS=

# ── ERC-8004 — canonical Mantle mainnet addresses (verified on-chain) ─────────
# Reputation Registry v2.0.0 — ERC-1967 proxy
ERC8004_REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
# Identity Registry (linked from ReputationRegistry.getIdentityRegistry())
ERC8004_IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432

# ── Tokens ─────────────────────────────────────────────────────────────────────
USDE_ADDRESS=0x5d3a1Ff2b6BAb83b63cd9AD0787074081a52ef34   # Ethena USDe on Mantle
USDC_ADDRESS=0x09Bc4E0D864854c6aFB6eB9A9cdF58aC190D0dF9   # USDC on Mantle

# ── Facilitator ────────────────────────────────────────────────────────────────
OPERATOR_ADDRESS=            # address derived from OPERATOR_PRIVATE_KEY
PROVIDER_ADDRESS=            # recipient of provider payouts from escrow; must differ from OPERATOR_ADDRESS
                             # run: cast wallet address --private-key $OPERATOR_PRIVATE_KEY
FACILITATOR_PORT=3001
FACILITATOR_FEE_BPS=20           # 0.2% taken from each settlement before paying provider
FACILITATOR_MIN_AMOUNT=100       # minimum payment in token base units (= 0.0001 USDC)

# ── Bazaar / Dashboard ─────────────────────────────────────────────────────────
BAZAAR_API_PORT=3002
NEXT_PUBLIC_FACILITATOR_URL=http://localhost:3001
NEXT_PUBLIC_BAZAAR_API=http://localhost:3002

# ── Spawn Protocol demo skills ────────────────────────────────────────────────
SPAWN_API_URL=http://localhost:3004
SPAWN_AGENT_PORT=3003
SPAWN_SKILL_BASE_URL=http://localhost:3003
SPAWN_PROVIDER_ADDRESS=            # provider wallet paid by the facilitator
CONSUMER_PRIVATE_KEY=0x             # demo consumer wallet; must hold USDC and approve OPERATOR_ADDRESS
DEMO_LINEAGE_KEY=demo-lineage
DEMO_GENERATION=1

# ── Mantle data skills (no external API key required) ─────────────────────────
MANTLE_SKILL_PORT=3005
MANTLE_SKILL_BASE_URL=http://localhost:3005

# ── Byreal skills (Solana CLMM + Perps, no API key required) ─────────────────
BYREAL_SKILL_PORT=3006
BYREAL_SKILL_PUBLIC_URL=https://ledgerforge-byreal.fly.dev

# ── API Keys ───────────────────────────────────────────────────────────────────
MANTLESCAN_API_KEY=              # from https://mantlescan.xyz/myapikey — needed for contract verification
