{
  "name": "@ledgerforge/x402-mantle",
  "version": "0.1.0",
  "description": "TypeScript SDK for the LedgerForge x402 payment rail on Mantle Network — discover, pay for, and execute on-chain agent skills.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "example": "tsx examples/quickstart.ts",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "x402",
    "mantle",
    "erc-8004",
    "agent",
    "payments",
    "stablecoin",
    "viem"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PoulavBhowmick03/ledgerforge",
    "directory": "sdk"
  },
  "dependencies": {
    "viem": "^2.x"
  },
  "peerDependencies": {
    "viem": "^2.x"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.22.3",
    "typescript": "^5.3.3"
  }
}
